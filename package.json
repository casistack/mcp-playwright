    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "shx": "^0.3.4",
    "ts-jest": "^29.1.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
